# .env.example — Vollständiger Integrationskatalog (Hausform 036).
#
# Zweck: Restore-/Deploy-Referenz. Nach `.env` kopieren und lokal befüllen;
# `.env` selbst ist gitignored (nur `.env.production` mit ausschließlich
# publishable Werten ist bewusst eingecheckt, siehe docs/code-review-2026-07.md §6).
# Betriebs-/Wiederherstellungs-Ablauf: docs/runbook-restore.md.
#
# Regeln:
# - Keine echten Werte in dieser Datei — alle Zeilen leer oder auskommentiert.
# - Quelle der Wahrheit ist der Code; jede Variable ist per Grep verifiziert
#   (Prüfer-Scan 18.07. auf aa9fc8eb) und mit Datei-Referenz kommentiert.
# - Server-only-Variablen erreichen den Browser-Bundle NICHT; nur `VITE_*`
#   wird von Vite build-time in den Client inlined.

# =============================================================================
# Supabase — PFLICHT
# Verhalten bei Fehlen: App startet mit Konfigurationsfehler-Screen; server
# functions werfen sofort. `SUPABASE_SERVICE_ROLE_KEY` ist server-only und
# umgeht RLS — niemals in Client-Code oder Logs.
# Hinweis: `SUPABASE_PROJECT_ID` (ohne VITE_) wird vom App-Code NICHT gelesen;
# er lebt ausschließlich in supabase/config.toml.
# =============================================================================

# src/integrations/supabase/client.server.ts (server), src/test/db-setup.ts
SUPABASE_URL=
# src/test/db-setup.ts, src/lib/auth/pin-attempt-register.db.test.ts
SUPABASE_ANON_KEY=
# src/lib/auth/auth-flows.server.ts, src/integrations/supabase/client.server.ts
SUPABASE_PUBLISHABLE_KEY=
# src/integrations/supabase/client.server.ts — SERVER-ONLY, RLS-Bypass!
SUPABASE_SERVICE_ROLE_KEY=

# Client-Bundle (VITE_*): werden build-time in den Browser inlined.
# src/routes/_authenticated/admin/config-check.tsx
VITE_SUPABASE_PROJECT_ID=
# src/integrations/supabase/client.ts, playwright.config.ts, e2e/global-setup.ts
VITE_SUPABASE_URL=
# src/integrations/supabase/client.ts, playwright.config.ts
VITE_SUPABASE_PUBLISHABLE_KEY=

# =============================================================================
# Tests / E2E — nur lokal & CI
# Verhalten bei Fehlen: DB-Integrationstests werden übersprungen (grün);
# E2E-Seed nutzt Default-Passwort. Nicht in Produktion setzen.
# =============================================================================

# vitest.config.ts, src/test/db-setup.ts
# Aktiv NUR mit lokal hochgezogenem Supabase-Stack (`supabase start`), sonst
# schlagen DB-Tests rot fehl. Bewusst auskommentiert lassen:
# SUPABASE_DB_TESTS=1

# e2e/seed.ts
E2E_PASSWORD=

# =============================================================================
# KI / Frag COCO
# Verhalten bei Fehlen: Frag-COCO-Antworten fallen auf Lovable-Gateway zurück
# bzw. schlagen fehl, wenn auch `LOVABLE_API_KEY` fehlt.
# =============================================================================

# src/lib/ki/anthropic-client.ts — PFLICHT wenn Claude-Pfad aktiv
ANTHROPIC_API_KEY=
# src/lib/ki/anthropic-client.ts — optional (Default: https://api.anthropic.com)
COCO_KI_BASE_URL=
# src/lib/ki/anthropic-client.ts, src/lib/ki/ask-coco.functions.ts — optional
COCO_KI_MODEL=
# src/routes/api/public/telegram/webhook.ts, src/lib/geo/geocoding.server.ts,
# src/lib/telegram/telegram.functions.ts, src/lib/bestellung/wine-research.functions.ts
LOVABLE_API_KEY=

# =============================================================================
# Bank-Sync (GoCardless BAD) — optional (BK2, aktuell inaktiv)
# Verhalten bei Fehlen: Bank-Sync-Endpunkt antwortet mit Konfigurationsfehler.
# =============================================================================

# src/lib/bank/gocardless.server.ts
GOCARDLESS_BAD_SECRET_ID=
# src/lib/bank/gocardless.server.ts
GOCARDLESS_BAD_SECRET_KEY=

# =============================================================================
# Mail (MailerSend) — PFLICHT für Bestell- und Systemmails
# Verhalten bei Fehlen: Mail-Versand wirft; Inbound-Webhook verwirft mangels
# Signaturprüfung.
# =============================================================================

# src/lib/bestellung/send-order-email.server.ts, src/routes/api/public/mailersend/webhook.ts
MAILERSEND_API_KEY=
# src/lib/bestellung/send-order-email.server.ts, src/routes/api/public/mailersend/webhook.ts
MAILERSEND_FROM_EMAIL=
# src/lib/bestellung/send-order-email.server.ts, src/routes/api/public/mailersend/webhook.ts
# Optional (Fallback: „Bestellung COCO“)
MAILERSEND_FROM_NAME=
# src/routes/api/public/mailersend/webhook.ts — Signatur-Secret für Inbound
MAILERSEND_WEBHOOK_SECRET=

# =============================================================================
# Inbound-Mail
# Verhalten bei Fehlen: Nicht zuordenbare Antworten werden verworfen (Log).
# =============================================================================

# src/routes/api/public/mailersend/webhook.ts
INBOUND_DEFAULT_ORGANIZATION_ID=

# =============================================================================
# Telegram
# Verhalten bei Fehlen: Bot-Webhook/Tagesbericht deaktiviert (401 bzw. no-op).
# =============================================================================

# src/lib/telegram/telegram.functions.ts, src/routes/api/public/telegram/webhook.ts
TELEGRAM_API_KEY=
# src/routes/api/public/telegram/daily-report.ts — Header-Secret für Cron
TELEGRAM_CRON_SECRET=

# =============================================================================
# Cron / Public-API Webhooks
# Verhalten bei Fehlen: Public-Cron-Endpunkte antworten 401.
# Bewusst getrennt von TELEGRAM_CRON_SECRET (unterschiedliche Aufrufer).
# =============================================================================

# src/routes/api/public/bank/sync-spicery.ts
CRON_SECRET=

# =============================================================================
# Monitoring
# Verhalten bei Fehlen: Sentry-Init no-op (kein Fehler-Reporting).
# =============================================================================

# src/lib/monitoring/sentry.server.ts, src/lib/monitoring/sentry-config.functions.ts
SENTRY_DSN=

# =============================================================================
# Sonstiges
# =============================================================================

# src/lib/geo/geocoding.server.ts — optional (Fallback: Lovable Maps-Connector)
GOOGLE_MAPS_API_KEY=
# src/lib/bestellung/wine-research.functions.ts — optional (Wein-Recherche)
FIRECRAWL_API_KEY=
# src/lib/monitoring/sentry.server.ts, src/lib/monitoring/sentry-config.functions.ts
# Wird von der Laufzeit gesetzt (`production`/`development`/`test`) — NICHT manuell pflegen.
# NODE_ENV=